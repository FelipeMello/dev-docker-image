# -----------------------------------------------------------------------------
# Copy to .env in THIS directory (next to docker-compose.yml).
#   cp .env.example .env
# Never commit .env.
# -----------------------------------------------------------------------------

# PostgreSQL (database + DATABASE_URL in dev use the same values)
POSTGRES_USER=pern
POSTGRES_PASSWORD=pern_dev_change_me
POSTGRES_DB=pern

# Host port → container 5432 (change if you already use 5432 locally)
# PERN_PG_PORT=5432

# Host port → container SSH :22 (default 2223)
# PERN_SSH_PORT=2223

# Optional SSH password for root — see README
# SSH_ROOT_PASSWORD='your-secret-here'
