# -----------------------------------------------------------------------------
# Copy to .env in THIS directory (next to docker-compose.yml).
#   cp .env.example .env
# The real .env file is gitignored — never commit it.
# -----------------------------------------------------------------------------

# Required by the Oracle Free image at first startup (default below is dev-only).
# ORACLE_PASSWORD=OracleDev_1

# Optional: SSH password for root inside the dev container.
# SSH_ROOT_PASSWORD='your-secret-here'

# Host port for Oracle listener (container stays on 1521)
# ORACLE_PORT=1521

# Host port mapped to container SSH :22 (default 2224 — avoids clashing with MERN/PERN)
# JAVA_ORACLE_SSH_PORT=2224
