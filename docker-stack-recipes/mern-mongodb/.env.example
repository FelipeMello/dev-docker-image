# -----------------------------------------------------------------------------
# Copy to .env in THIS directory (next to docker-compose.yml).
#   cp .env.example .env
# The real .env file is gitignored — never commit it.
# -----------------------------------------------------------------------------

# Optional: SSH password for root inside the dev container.
# If unset or empty, SSH accepts keys only (run ./setup-ssh.sh). After changing,
# recreate the dev container: docker compose up -d --force-recreate dev
#
# Use single quotes if the password contains # $ spaces or other specials:
# SSH_ROOT_PASSWORD='your-secret-here'
#
# SSH_ROOT_PASSWORD=

# Optional: host port mapped to container SSH :22 (default 2222)
# MERN_SSH_PORT=2222
